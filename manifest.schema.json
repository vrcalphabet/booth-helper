{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "このリポジトリ（拡張機能セット）の名称"
    },
    "extensions": {
      "type": "array",
      "minItems": 1,
      "description": "このリポジトリに含まれる拡張機能の一覧",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "拡張機能のID。英数字・アンダーバー・ハイフンのみ。IDはリポジトリ内で重複不可です。",
            "pattern": "^[\\w-]+$"
          },
          "name": {
            "type": "string",
            "description": "拡張機能の表示名"
          },
          "description": {
            "type": "string",
            "description": "拡張機能の概要（何をする拡張機能か）"
          },
          "version": {
            "type": "string",
            "description": "拡張機能のバージョン。`x.x.x` 形式。",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "author": {
            "type": "string",
            "description": "拡張機能の作者名"
          },
          "published_at": {
            "type": "string",
            "description": "公開日。`yyyy-mm-dd` 形式。",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "updated_at": {
            "type": "string",
            "description": "更新日。`yyyy-mm-dd` 形式。",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "contents": {
            "type": "array",
            "minItems": 1,
            "description": "ページ上で読み込んで実行する JS/CSS の定義",
            "items": {
              "type": "object",
              "properties": {
                "matches": {
                  "type": "array",
                  "minItems": 1,
                  "description": "読み込み対象のURLパターン。例: `//booth.pm/*/items/ja`、`//*.booth.pm/items/*`。",
                  "items": {
                    "type": "string",
                    "pattern": "^(//(\\*\\.|[\\w-]+\\.)?booth\\.pm/(([\\w-]+|\\*)(/([\\w-]+|\\*))*)/?|\\<all_pages\\>)$"
                  }
                },
                "files": {
                  "type": "array",
                  "minItems": 1,
                  "description": "実行するファイルの、 `/src/拡張機能id` から見た相対パス。拡張子は `.js` `.jsx` `.ts` `.tsx` `.css` `.scss` `.sass` のいずれかを指定できます。",
                  "items": {
                    "type": "string",
                    "pattern": "^([\\w-]+/)*[\\w-]+\\.(js|jsx|ts|tsx|css|scss|sass)$"
                  }
                }
              },
              "additionalProperties": false,
              "required": ["matches", "files"]
            }
          },
          "settings": {
            "type": "object",
            "description": "設定画面とその項目の一覧が定義されているスキーマ。",
            "properties": {
              "schema": {
                "type": "string",
                "description": "設定項目が定義されているスキーマ",
                "pattern": "^([\\w-]+/)*[\\w-]+\\.json$"
              },
              "uiSchema": {
                "type": "string",
                "description": "設定画面が定義されているスキーマ",
                "pattern": "^([\\w-]+/)*[\\w-]+\\.json$"
              },
              "formData": {
                "type": "string",
                "description": "設定項目の初期値が定義されているスキーマ",
                "pattern": "^([\\w-]+/)*[\\w-]+\\.json$"
              }
            },
            "additionalProperties": false,
            "required": ["schema", "uiSchema", "formData"]
          }
        },
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "version",
          "author",
          "published_at",
          "updated_at",
          "contents"
        ]
      }
    }
  },
  "additionalProperties": false,
  "required": ["name", "extensions"]
}
