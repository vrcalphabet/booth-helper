{
  "name": "ちょっとだけ使いやすくなる拡張機能セット",
  "extensions": [
    {
      "id": "hide-nsfw",
      "name": "R-18商品をモザイクにするやつ",
      "description": "R-18商品をモザイクにできます。",
      "version": "1.0.0",
      "author": "あるふぁべっと",
      "published_at": "2025-12-01",
      "updated_at": "2025-12-01",
      "contents": [
        {
          "matches": [
            "<all_pages>"
          ],
          "files": [
            "/dist/hide-nsfw/styles/style.css"
          ]
        },
        {
          "matches": [
            "//booth.pm/ja"
          ],
          "files": [
            "/dist/hide-nsfw/scripts/main.js"
          ]
        }
      ]
    }
  ]
}
