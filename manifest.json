{
  "name": "ちょっとだけ使いやすくなる拡張機能セット",
  "extensions": [
    {
      "id": "hide-nsfw",
      "name": "R-18商品をモザイクにするやつ",
      "description": "R-18商品をモザイクにできます。",
      "version": "1.0.0",
      "author": "あるふぁべっと",
      "published_at": "2025-12-01",
      "updated_at": "2025-12-01",
      "contents": [
        {
          "matches": [
            "<all_pages>"
          ],
          "files": [
            "/dist/hide-nsfw/styles/style.css"
          ]
        },
        {
          "matches": [
            "//booth.pm/ja"
          ],
          "files": [
            "/dist/hide-nsfw/scripts/main.js"
          ]
        }
      ]
    },
    {
      "id": "tldr",
      "name": "メッセージを今北産業するやつ",
      "description": "",
      "version": "1.0.0",
      "author": "あるふぁべっと",
      "published_at": "2026-03-12",
      "updated_at": "2026-03-12",
      "contents": [
        {
          "matches": [
            "<all_pages>"
          ],
          "files": [
            "/dist/tldr/main.js"
          ]
        }
      ],
      "settings": "/dist/tldr/settings.json"
    }
  ]
}
